{
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "printWidth": 80,
  "overrides": [
    {
      "files": "*.mdx",
      "options": {
        "printWidth": 100
      }
    },
    {
      "files": "apps/slides/*.md",
      "options": {
        "printWidth": 120,
        "proseWrap": "preserve"
      }
    }
  ]
}
