{
  // Editor settings
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [80],
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 80,
  "editor.bracketPairColorization.enabled": false,
  // File settings
  "files.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true,
    "**/.nyc_output": true,
    "**/tmp": true,
    "**/temp": true,
    "**/.cache": true,
    "**/pnpm-lock.yaml": true,
    "**/.source": true,
    "**/next-env.d.ts": true,
    "**/.contentlayer": true,
    "**/.content-collections": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/.husky": true,
    "**/reports": true,
    "**/.augment": true,
    "**/.trae": true,
    "**/.gitmessage": true,
    "**/cli.json": true,
    "**/.nvmrc": true,
    "**/.pnpm-store": true,
    "**/drizzle": true,
    "tsconfig.tsbuildinfo": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    ".env": ".env.*",
    "package.json": "*.config.ts, *.config.js, *.config.mjs, *.config.cjs, .npmrc, .nvmrc, yarn.lock, pnpm-lock.yaml, tsconfig*.json, *.config.mts, components.json",
    "README.md": "CHANGELOG.md, LICENSE, LICENSE.md, CONTRIBUTING.md"
  },
  // Format settings for specific languages
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.rulers": [],
    "editor.wordWrap": "on"
  },
  "[mdx]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // TypeScript settings
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  // Tailwind CSS settings
  "tailwindCSS.includeLanguages": {
    "typescript": "typescript",
    "typescriptreact": "typescriptreact"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  // Git settings
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  // Search settings
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/out": true,
    "**/build": true,
    "**/*.lock": true
  },
  // VSCode integrated Copilot Commit Message Templates
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use conventional commit format: type(scope): description"
    },
    {
      "text": "Keep the entire generated commit message under 25 words; be concise"
    },
    {
      "text": "Type must be one of: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test"
    },
    {
      "text": "Type must be in lowercase"
    },
    {
      "text": "Subject must start with lowercase, avoid sentence-case, start-case, pascal-case, or upper-case"
    },
    {
      "text": "Subject must not end with a period (.)"
    },
    {
      "text": "Use imperative mood: 'add feature' not 'added feature'"
    },
    {
      "text": "Generate commit messages in English only"
    }
  ],
  "slidev.include": ["content/slides/midterm-2.md"]
}
