{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.21.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "fumadocs-mdx && next build --turbopack",
    "start": "next start --port 3001",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check --diagnostic-level=error .",
    "lint:fix": "biome check --write .",
    "format": "biome check --write --linter-enabled=false .",
    "format:check": "biome check --linter-enabled=false ."
  },
  "dependencies": {
    "fumadocs-core": "^15.8.5",
    "fumadocs-mdx": "^12.0.3",
    "fumadocs-twoslash": "^3.1.8",
    "fumadocs-ui": "^15.8.5",
    "@types/mdx": "^2.0.13",
    "next": "15.5.9",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "next-themes": "^0.4.6",
    "lucide-react": "^0.545.0",
    "katex": "^0.16.25",
    "mermaid": "^11.12.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.13.0",
    "twoslash": "^0.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "geist": "^1.5.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "unist-util-visit": "^5.0.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/hast": "^3.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@biomejs/biome": "^2.3.10"
  }
}
