{
  "name": "storybook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.21.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "preview": "npx http-server storybook-static",
    "test": "cross-env NODE_ENV=test vitest",
    "test:run": "cross-env NODE_ENV=test vitest --run --silent=true",
    "lint": "biome check --diagnostic-level=error .",
    "lint:fix": "biome check --write .",
    "format": "biome check --write --linter-enabled=false .",
    "format:check": "biome check --linter-enabled=false .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf storybook-static node_modules .turbo"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@nomad/ui": "workspace:*",
    "date-fns": "^4.1.0",
    "next-themes": "^0.4.6",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-hook-form": "^7.69.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@chromatic-com/storybook": "^4.1.1",
    "@storybook/addon-a11y": "^9.1.15",
    "@storybook/addon-docs": "^9.1.15",
    "@storybook/addon-onboarding": "^9.1.15",
    "@storybook/addon-vitest": "^9.1.15",
    "@storybook/react": "^9.1.15",
    "@storybook/react-vite": "^9.1.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "jsdom": "25.0.1",
    "playwright": "^1.56.1",
    "remark-gfm": "^4.0.1",
    "storybook": "^9.1.15",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.0.5",
    "vitest": "^3.2.4"
  }
}
