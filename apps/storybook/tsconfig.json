{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@nomad/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "src/**/*",
    ".storybook/**/*",
    "**/*.stories.tsx",
    "**/*.stories.ts",
    "**/*.mdx"
  ],
  "exclude": ["node_modules", "storybook-static"]
}
