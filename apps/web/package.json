{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.21.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "cross-env NODE_ENV=test vitest",
    "test:run": "cross-env NODE_ENV=test vitest --run --silent=true",
    "test:unit": "cross-env NODE_ENV=test vitest --run --project=unit",
    "test:repository": "cross-env NODE_ENV=test vitest --run --project=repository",
    "test:integration": "cross-env NODE_ENV=test vitest --run --project=integration",
    "test:integration:watch": "cross-env NODE_ENV=test vitest --project=integration",
    "test:storybook": "cross-env NODE_ENV=test vitest --run --project=storybook",
    "test:coverage": "vitest --run --coverage",
    "test:ac-coverage": "tsx ../../packages/requirements/src/cli/coverage.ts",
    "test:report": "pnpm test:coverage && pnpm e2e && node scripts/generate-dashboard.js",
    "test:ui": "vitest --ui",
    "e2e": "cross-env NODE_ENV=test playwright test",
    "e2e:ui": "cross-env NODE_ENV=test playwright test --ui",
    "e2e:headed": "cross-env NODE_ENV=test playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:debug": "cross-env NODE_ENV=test playwright test --debug",
    "db:push": "drizzle-kit push",
    "db:push:test": "cross-env NODE_ENV=test drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:studio:test": "cross-env NODE_ENV=test drizzle-kit studio",
    "db:seed": "cross-env NODE_ENV=development tsx src/db/data/seed.runner.ts",
    "lint": "biome check --diagnostic-level=error . && pnpm lint:boundary",
    "lint:fix": "biome check --write . && pnpm lint:boundary",
    "lint:boundary": "node scripts/check-app-boundary.mjs",
    "format": "biome check --write --linter-enabled=false . && prettier --write '**/*.{md,vue}' --ignore-path .prettierignore",
    "format:check": "biome check --linter-enabled=false . && prettier --check '**/*.{md,vue}' --ignore-path .prettierignore",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "email": "email dev --dir ./app/_components/emails --port 6007",
    "clean": "rm -rf .next .turbo node_modules",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.22",
    "@ai-sdk/react": "^2.0.76",
    "@alicloud/credentials": "^2.4.4",
    "@alicloud/dypnsapi20170525": "2.0.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.10",
    "@marsidev/react-turnstile": "^1.3.1",
    "@next/env": "^16.0.1",
    "@nomad/ui": "workspace:*",
    "@react-email/components": "^0.5.6",
    "@types/mdx": "^2.0.13",
    "ai": "^5.0.76",
    "ajv": "^8.17.1",
    "better-auth": "^1.3.27",
    "currency.js": "^2.0.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.44.6",
    "drizzle-query-logger": "^1.1.1",
    "drizzle-seed": "^0.3.1",
    "geist": "^1.5.1",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.6",
    "next": "15.5.9",
    "pg": "^8.16.3",
    "pino": "^10.0.0",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-remove-scroll": "^2.7.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "resend": "^6.1.2",
    "sonner": "^2.0.7",
    "unist-util-visit": "^5.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.2.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@chromatic-com/storybook": "^4.1.1",
    "@faker-js/faker": "^10.0.0",
    "@inquirer/prompts": "^7.9.0",
    "@neondatabase/api-client": "^2.2.0",
    "@playwright/test": "^1.56.0",
    "@react-email/preview-server": "4.3.2",
    "@storybook/addon-a11y": "^9.1.15",
    "@storybook/addon-docs": "^9.1.15",
    "@storybook/addon-onboarding": "^9.1.15",
    "@storybook/addon-vitest": "^9.1.15",
    "@storybook/nextjs-vite": "^9.1.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/zxcvbn": "^4.4.5",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "3.2.4",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.5",
    "fishery": "^2.3.1",
    "jsdom": "25.0.1",
    "ora": "^8.2.0",
    "pino-pretty": "^13.1.2",
    "playwright": "^1.56.1",
    "prettier": "^3.7.4",
    "react-email": "4.3.2",
    "server-only": "^0.0.1",
    "storybook": "^9.1.15",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
