{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/actions/*": ["./app/_actions/*"],
      "@/components/*": ["./app/_components/*"],
      "@/hooks/*": ["./app/_hooks/*"],
      "@/stories/*": ["./app/_stories/*"],
      "@/app/*": ["./app/*"],
      "@/*": ["./src/*"],
      "@/tests/*": ["./tests/*"],
      "@ukesjtu/nomad-ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "scripts/**/*.js"
  ]
}
