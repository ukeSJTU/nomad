{
  "name": "nomad",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.21.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:cache": "turbo daemon stop && rm -rf .turbo",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:start": "pnpm --filter web start",
    "web:test": "pnpm --filter web test",
    "web:test:run": "pnpm --filter web test:run",
    "web:test:ui": "pnpm --filter web test:ui",
    "web:e2e": "pnpm --filter web e2e",
    "web:lint": "pnpm --filter web lint",
    "web:db:push": "pnpm --filter web db:push",
    "web:db:studio": "pnpm --filter web db:studio",
    "web:db:seed": "pnpm --filter web db:seed",
    "web:storybook": "pnpm --filter web storybook",
    "web:build-storybook": "pnpm --filter web build-storybook",
    "web:email": "pnpm --filter web email",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:start": "pnpm --filter docs start",
    "docs:lint": "pnpm --filter docs lint",
    "slides:dev": "pnpm --filter slides dev",
    "slides:build": "pnpm --filter slides build",
    "slides:export": "pnpm --filter slides export",
    "demo:dev": "pnpm --filter demo dev",
    "demo:build": "pnpm --filter demo build",
    "demo:start": "pnpm --filter demo start",
    "demo:lint": "pnpm --filter demo lint",
    "demo:remotion": "pnpm --filter demo remotion",
    "demo:render": "pnpm --filter demo render",
    "check:deps": "pnpm outdated -r",
    "update:deps": "pnpm update -r --interactive --latest",
    "turbo:graph": "turbo run build --graph=graph.html",
    "turbo:dry": "turbo run build --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.7.4",
    "prettier-plugin-slidev": "^1.0.5",
    "turbo": "^2.7.2",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "*.vue": [
      "prettier --write"
    ]
  }
}
