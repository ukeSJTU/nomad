{
  "name": "nomad",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.21.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:test": "pnpm --filter web test",
    "web:e2e": "pnpm --filter web e2e",
    "web:db:push": "pnpm --filter web db:push",
    "web:db:studio": "pnpm --filter web db:studio",
    "web:db:seed": "pnpm --filter web db:seed",
    "web:storybook": "pnpm --filter web storybook",
    "web:build-storybook": "pnpm --filter web build-storybook",
    "web:email": "pnpm --filter web email",
    "slides:dev": "pnpm --filter slides dev",
    "slides:build": "pnpm --filter slides build",
    "slides:export": "pnpm --filter slides export",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.7.4",
    "prettier-plugin-slidev": "^1.0.5",
    "turbo": "^2.7.2",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "*.vue": [
      "prettier --write"
    ]
  }
}
