{
  "name": "@nomad/requirements",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./data": "./src/data/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/data/types.ts"
  },
  "scripts": {
    "lint": "biome check .",
