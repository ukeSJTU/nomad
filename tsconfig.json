{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/actions/*": ["./app/_actions/*"],
      "@/components/*": ["./app/_components/*"],
      "@/hooks/*": ["./app/_hooks/*"],
      "@/stories/*": ["./app/_stories/*"],
      "@/app/*": ["./app/*"],
      "@/*": ["./src/*"],
      "@/.source": ["./.source"],
      "@/tests/*": ["./tests/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "scripts/**/*.js",
    ".source"
  ]
}
